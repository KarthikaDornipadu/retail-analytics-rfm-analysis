   "source": [
    "rfm = df.groupby('Customer_ID').agg({\n",
    "    'Order_Date': lambda x: (snapshot_date - x.max()).days,   # Recency\n",
    "    'Customer_ID': 'count',                            # Frequency\n",
    "    'Total_Amount': 'sum'                              # Monetary\n",
    "})\n",
    "\n",
    "rfm.columns = ['Recency', 'Frequency', 'Monetary']\n",
    "rfm.head()"
   ]
  },
